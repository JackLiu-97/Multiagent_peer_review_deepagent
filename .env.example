DEEPAGENT_MODEL=gpt-4o-mini

# Use one of the supported API key names. Leave blank in committed examples.
DEEPAGENT_API_KEY=
OPENAI_API_KEY=

# Optional OpenAI-compatible endpoint, for example a proxy or third-party base URL.
DEEPAGENT_BASE_URL=
OPENAI_BASE_URL=

MAX_REVIEW_ROUNDS=2
MAX_TOOL_ROUNDS=6

# Optional history database connection string. Keep real credentials only in .env.
HISTORY_DATABASE_URL=
HISTORY_SCHEMA_NAME=

REVIEW_OUTPUT_DIR=outputs
LOG_LEVEL=INFO
CONSOLE_LOG_ENABLED=true
